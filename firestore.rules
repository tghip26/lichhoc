rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hàm phụ trợ kiểm tra vai trò người dùng an toàn (không bị crash nếu chưa có tài liệu user)
    function hasRole(role) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'hiplaika263@gmail.com' || hasRole('admin'));
    }
    
    function isHelper() {
      return hasRole('helper');
    }

    function isStaff() {
      return hasRole('staff');
    }

    // 1. Quy tắc cho bộ sưu tập 'users' (Tài khoản người dùng)
    match /users/{userId} {
      // Người dùng chỉ được xem và tự cập nhật thông tin của mình. Admin được toàn quyền.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isHelper());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 2. Quy tắc cho bộ sưu tập 'schedules' (Đơn thuê học)
    match /schedules/{scheduleId} {
      // Khách hàng tự đọc đơn của mình. Admin & CTV được xem toàn bộ.
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isHelper());
      // Khách hàng tự tạo đơn và cập nhật đơn của mình. Admin & CTV được phép xử lý đơn.
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin() || isHelper());
    }

    // 3. Quy tắc cho bộ sưu tập 'transactions' (Lịch sử nạp/rút tiền ví)
    match /transactions/{transactionId} {
      // Khách hàng tự xem lịch sử của mình. Admin được xem toàn bộ.
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Người dùng đã đăng nhập được tạo giao dịch mới ở trạng thái chờ duyệt (pending). Admin được tạo giao dịch trực tiếp.
      allow create: if request.auth != null && (request.resource.data.status == 'pending' || isAdmin());
      // Chỉ Admin mới được quyền cập nhật hoặc xóa giao dịch
      allow update, delete: if isAdmin();
    }

    // 4. Quy tắc cho bộ sưu tập 'notifications' (Thông báo hệ thống)
    match /notifications/{notifId} {
      // Chỉ đọc thông báo gửi đích danh cho mình hoặc thông báo chung của admin.
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || (resource.data.userId == 'admin' && isAdmin()));
      // Người dùng được tạo thông báo gửi cho Admin và ngược lại. Người dùng tự đánh dấu đã đọc/xóa thông báo của mình.
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 5. Quy tắc cho bộ sưu tập 'reviews' (Đánh giá trang chủ)
    match /reviews/{reviewId} {
      // Cho phép mọi người (kể cả chưa đăng nhập) đọc đánh giá ở trang chủ.
      allow read: if true;
      // Chỉ người dùng đã đăng nhập mới được tạo đánh giá mới.
      allow create: if request.auth != null;
      // Chỉ Admin được sửa hoặc xóa đánh giá.
      allow update, delete: if isAdmin();
    }

    // 6. Quy tắc cho bộ sưu tập 'settings' (Cấu hình hệ thống)
    match /settings/{docName} {
      // Cho phép mọi người đọc thông tin chung (hotline, số tài khoản, thông báo)
      allow read: if true;
      // Chỉ Admin mới được quyền thay đổi cấu hình.
      allow write: if isAdmin();
    }

    // Quy tắc cho bộ sưu tập chỉ mục email công khai (Không cho phép list/scrape dữ liệu)
    match /user_emails_index/{emailId} {
      allow get: if true;
      allow list: if false;
      allow write: if request.auth != null;
    }

    // 7. Quy tắc cho bộ sưu tập 'helpers' (Hồ sơ đăng ký CTV)
    match /helpers/{helperId} {
      // Cho phép mọi người tạo đơn đăng ký CTV
      allow create: if true;
      // Cho phép mọi người đọc nếu hồ sơ đã được duyệt. Hồ sơ chưa duyệt chỉ người nộp hoặc Admin được đọc.
      allow read: if (resource.data.status == 'approved' || resource.data.isApproved == true) || 
                    (request.auth != null && (resource.data.userId == request.auth.uid || isAdmin()));
      // Chỉ người nộp hồ sơ hoặc Admin mới được cập nhật
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      // Chỉ Admin mới được xóa hồ sơ đăng ký CTV
      allow delete: if isAdmin();
    }

    // 8. Quy tắc cho bộ sưu tập 'internal_schedules' (Lịch nội bộ Admin & Nhân viên quản lý)
    match /internal_schedules/{scheduleId} {
      allow read, write: if request.auth != null && (isAdmin() || isStaff());
    }

    // 9. Quy tắc cho bộ sưu tập 'internal_customers' (Khách hàng nội bộ)
    match /internal_customers/{customerId} {
      allow read, write: if request.auth != null && (isAdmin() || isStaff());
    }

    // 10. Quy tắc cho bộ sưu tập 'contact_messages' (Lời nhắn liên hệ)
    match /contact_messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && (isAdmin() || isStaff());
    }
  }
}
